# ============================================================
# LAMEDA ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# SUPABASE
# Safe in client bundle - RLS enforces all access control.
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only - never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Runtime alias of NEXT_PUBLIC_SUPABASE_URL for server-side clients.
# NEXT_PUBLIC_ vars are baked at build time and may be undefined at runtime.
SUPABASE_URL=https://your-project-ref.supabase.co

# ------------------------------------------------------------
# TELEGRAM (Active channel)
# Create a bot via @BotFather on Telegram.
# TELEGRAM_BOT_TOKEN     → the token BotFather gives you
# TELEGRAM_WEBHOOK_SECRET → any random string (16-32 chars).
#                           Set the same value in setup-telegram.mjs.
# Run: node scripts/setup-telegram.mjs to register the webhook.
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string

# ------------------------------------------------------------
# WHATSAPP (Future channel - not active yet)
# Uncomment and fill in when switching from Telegram to WhatsApp.
# Docs: https://developers.termii.com
# ------------------------------------------------------------
# TERMII_API_KEY=your-termii-api-key
# TERMII_SENDER_ID=your-sender-id
# TERMII_WEBHOOK_SECRET=your-webhook-verification-token

# ------------------------------------------------------------
# AI (Anthropic Claude)
# Server-side only. Used for intent classification + responses.
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key

# ------------------------------------------------------------
# PAYMENTS (Paystack)
# Public key safe in client. Secret key server-side only.
# ------------------------------------------------------------
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-key
PAYSTACK_SECRET_KEY=sk_test_your-key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Lameda
NODE_ENV=development

# ------------------------------------------------------------
# TECHNICAL DEBT NOTES
# - Termii webhook secret verification uses HMAC-SHA512.
#   If switching BSP, update src/lib/whatsapp/verify.ts.
# - Paystack uses HMAC-SHA512 for webhook verification.
# - Service role key bypasses RLS - use only in server contexts.
# ------------------------------------------------------------
